<?xml version='1.0' encoding='UTF-8' ?>

<!DOCTYPE server PUBLIC
   "-//JBoss//DTD MBean Service 3.2//EN"
   "http://www.jboss.org/j2ee/dtd/jboss-service_3_2.dtd"
>
<server>
  <mbean code="org.jboss.jms.server.destination.QueueService"
    name="dcm4chee.cdw:service=Queue,name=PTPublish"
    xmbean-dd="xmdesc/Queue-xmbean.xml">
      <depends optional-attribute-name="ServerPeer">jboss.messaging:service=ServerPeer</depends>
      <depends>jboss.messaging:service=PostOffice</depends>
  </mbean>
  <mbean code="org.dcm4chex.cdw.ptpublish.PTPublishService"
    name="dcm4chee.cdw:service=MediaWriter,name=PTPublish"
    xmbean-dd="xmdesc/dcm4chee-cdw-ptpublish-xmbean.xml">
    <attribute name="PrintLabel">false</attribute>
    <attribute name="JobTimeoutSecs">120</attribute>
    <attribute name="NumberOfRetries">0</attribute>
    <depends>jboss.messaging.connectionfactory:service=ConnectionFactory</depends>
    <depends>dcm4chee.cdw:service=Queue,name=PTPublish</depends>
    <depends optional-attribute-name="SpoolDirName"
      >dcm4chee.cdw:service=SpoolDir</depends>
  </mbean>
</server>
